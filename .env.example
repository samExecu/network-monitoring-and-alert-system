# Make a copy of this file named ".env" and fill in your values

# Discord Webhook
# How to get: Discord Server > Edit Channel > Integrations > Webhooks > New Webhook > Copy URL
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN
# Email alerts via Gmail
# How to get app password: Google Account > Security > 2-Step Verification > App Passwords
EMAIL_SENDER=youremail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_RECIPIENT=youremail@gmail.com
